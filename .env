# ============================================================================
# Nexus Cloud - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit the .env file with actual values to version control
# ============================================================================

# ----------------------------------------------------------------------------
# AWS Secrets Manager Secret Names
# ----------------------------------------------------------------------------
# All API keys and credentials are stored in AWS Secrets Manager
# Create these secrets BEFORE deploying the CDK stack
# Use: aws secretsmanager create-secret --name <name> --secret-string '<json>'
# ----------------------------------------------------------------------------

# OpenAI API Key (no longer used by the Lambda pipeline — all AI passes now run on AWS Bedrock)
# Secret: nexus/openai_api_key
# JSON: {"api_key": "sk-..."}
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Perplexity API Key (for sonar-pro research)
# Secret: nexus/perplexity_api_key
# JSON: {"api_key": "pplx-..."}
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# ElevenLabs API Key (for text-to-speech)
# Secret: nexus/elevenlabs_api_key
# JSON: {"api_key": "..."}
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=...

# Pexels & Pixabay API Keys (for stock video/images)
# Secret: nexus/pexels_api_key
# JSON: {"api_key": "...", "pixabay_key": "..."}
# Get from: https://www.pexels.com/api/ and https://pixabay.com/api/docs/
PEXELS_API_KEY=...
PIXABAY_API_KEY=...

# Storyblocks API Keys (for premium stock footage)
# Secret: nexus/storyblocks_api_key
# JSON: {"api_key": "...", "private_key": "..."}
# Get from: https://www.storyblocks.com/api
STORYBLOCKS_API_KEY=...
STORYBLOCKS_PRIVATE_KEY=...

# Runway ML API Key (for AI video generation)
# Secret: nexus/runwayml_api_key
# JSON: {"api_key": "..."}
# Get from: https://app.runwayml.com/settings/developer
RUNWAYML_API_KEY=...

# YouTube OAuth2 Credentials (for uploading videos)
# Secret: nexus/youtube_credentials
# JSON: {"client_id": "...", "client_secret": "...", "refresh_token": "..."}
# Get from: Google Cloud Console > APIs & Services > Credentials
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...

# Discord Webhook URL (for notifications)
# Secret: nexus/discord_webhook_url
# JSON: {"url": "https://discord.com/api/webhooks/..."}
# Get from: Discord Server > Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# PostgreSQL Database Credentials (for run logging)
# Secret: nexus/db_credentials
# JSON: {"host": "...", "port": "5432", "dbname": "...", "user": "...", "password": "..."}
# Use RDS or Aurora Serverless v2
DB_HOST=...
DB_PORT=5432
DB_NAME=nexus
DB_USER=...
DB_PASSWORD=...

# ----------------------------------------------------------------------------
# AWS Configuration (for CDK deployment)
# ----------------------------------------------------------------------------
# These are automatically set by 'aws configure' but can be overridden here

# AWS Region (must match CDK deployment region)
AWS_REGION=us-east-1

# AWS Account ID (optional, CDK will auto-detect)
AWS_ACCOUNT_ID=...

# ----------------------------------------------------------------------------
# AWS Resource ARNs (set automatically by CDK after deployment)
# ----------------------------------------------------------------------------
# These are outputs from the CDK stack and used by Lambda functions

# Step Functions State Machine ARN
STATE_MACHINE_ARN=arn:aws:states:REGION:ACCOUNT:stateMachine:nexus-pipeline

# AWS MediaConvert Role ARN (for video transcoding)
MEDIACONVERT_ROLE_ARN=arn:aws:iam::ACCOUNT:role/...

# ----------------------------------------------------------------------------
# S3 Bucket Names (created by CDK)
# ----------------------------------------------------------------------------

# Assets bucket (intermediate files: audio clips, video clips)
ASSETS_BUCKET=nexus-assets

# Outputs bucket (final videos, thumbnails)
OUTPUTS_BUCKET=nexus-outputs

# Config bucket (channel profiles, LUTs, SFX)
CONFIG_BUCKET=nexus-config

# Dashboard bucket (static website)
DASHBOARD_BUCKET=nexus-dashboard-ACCOUNT

# ----------------------------------------------------------------------------
# API Gateway (set after CDK deployment)
# ----------------------------------------------------------------------------

# API Gateway URL (from CDK output)
API_URL=https://xxxxxxxx.execute-api.REGION.amazonaws.com/prod

# ----------------------------------------------------------------------------
# CloudFront (set after CDK deployment)
# ----------------------------------------------------------------------------

# CloudFront distribution URL (dashboard access)
DASHBOARD_URL=https://xxxxxxxxxx.cloudfront.net

# ----------------------------------------------------------------------------
# Optional: Freesound API (for sound effects via scripts/upload_sfx.py)
# ----------------------------------------------------------------------------

# Freesound API Key (for downloading CC0 sound effects)
# Get from: https://freesound.org/apiv2/apply
FREESOUND_API_KEY=...

# ----------------------------------------------------------------------------
# Lambda Environment Variables (set automatically by CDK)
# ----------------------------------------------------------------------------
# These are configured in the CDK stack and don't need manual setup

# NOTIFY_MODE=error (for nexus-notify-error function)
# MEDIACONVERT_ROLE_ARN (injected into nexus-editor)
# STATE_MACHINE_ARN (injected into nexus-api)
# OUTPUTS_BUCKET (injected into nexus-api)

# ============================================================================
# Setup Instructions
# ============================================================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Fill in all API keys and credentials
#
# 3. Create AWS Secrets Manager secrets:
#    aws secretsmanager create-secret \
#      --name nexus/openai_api_key \
#      --secret-string '{"api_key":"sk-..."}'
#
#    (Repeat for all 9 secrets listed above)
#
# 4. Deploy CDK stack:
#    cd infrastructure && cdk deploy
#
# 5. Update .env with CDK outputs (ARNs, bucket names, URLs)
#
# 6. Deploy dashboard:
#    aws s3 cp dashboard/index.html s3://nexus-dashboard-ACCOUNT/
#
# ============================================================================
